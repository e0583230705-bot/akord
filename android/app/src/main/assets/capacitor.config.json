{
	"appId": "com.akord.guitar",
	"appName": "אקורד",
	"webDir": "www",
	"server": {
		"androidScheme": "https",
		"cleartext": false
	},
	"android": {
		"backgroundColor": "#0a0612",
		"allowMixedContent": false,
		"captureInput": true,
		"webContentsDebuggingEnabled": false
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 1500,
			"backgroundColor": "#0a0612",
			"androidSplashResourceName": "splash",
			"showSpinner": false
		},
		"StatusBar": {
			"style": "Dark",
			"backgroundColor": "#0a0612"
		}
	}
}
